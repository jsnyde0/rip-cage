# Effective rip-cage config (rc config show)
# Layers loaded:
#   global  = <GM_ROOT>/home/.config/rip-cage/config.yaml
#   project = <GM_ROOT>/workspace/.rip-cage.yaml
#
version: 2               # from project
mounts:
  denylist: []                 # from global
  allow_risky: null               # from default
  config_mode: ro               # from default
  symlinks:
    on_dangling: follow               # from default
    scope: file               # from default
    mode: rw               # from default
network:
  allowed_hosts:                   # from project
    - example.com                 # project
dcg:
  packs: []                 # from default
  custom_rule_paths: []                 # from default
session:
  multiplexer: none               # from default
auth:
  credential_mounts: real               # from default
  placeholder_env_file: null               # from default
  per_tool:
    claude: null               # from default
    pi: null               # from default
  credentials: []                 # from default
# manifest egress (host manifest — pending, requires rebuild to change):
#   api.github.com               # manifest:beads
#   doltremoteapi.dolthub.com               # manifest:dolt
#   api.github.com               # manifest:gh
#   github.com               # manifest:gh