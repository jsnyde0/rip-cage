# OS
.DS_Store
Thumbs.db

# Editor / IDE
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# VS Code devcontainer path removed in rip-cage-kt25; entry kept to suppress any stale local dirs
.devcontainer/

# Homebrew tap repo (separate git repo, may be cloned as sibling)
homebrew-rip-cage/

# Environment / secrets
.env
.env.*
!.env.example
# .env-pi is not matched by .env.* (glob requires a dot after .env); add explicit rule
**/.env-pi

# Logs
*.log

# Python
__pycache__/
*.py[cod]
*.egg-info/
# dist/ holds Python build artifacts; ignore those but track the maintainer-authored
# distribution manifest (dist/default-tools.yaml — rip-cage-wlwc.12).
dist/*.whl
dist/*.tar.gz
dist/*.egg
build/
.venv/
venv/

# Node (if applicable)
node_modules/

# Go
vendor/

# Docker
*.tar

# Test / coverage
.coverage
htmlcov/
.pytest_cache/

# Beads (local database)
# .beads/   # memory-sync: keep .beads/issues.jsonl tracked (bd/.beads/.gitignore handles the DB/runtime)

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

docs/tmp/*

# Beads / Dolt files (added by bd init)
.beads/proxieddb/
# bd worktree
.worktrees/kstk/

# Claude Code agent worktrees (transient, per-subagent isolation)
.claude/worktrees/
