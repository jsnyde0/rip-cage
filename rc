# When sourced (e.g., by tests), skip dispatch — expose functions only.
# BASH_SOURCE[0] is the script file; $0 is the invoking shell when sourced.
# When piped via `bash -s --` (test-auth-refresh.sh's run_rc, to bypass the
# /.dockerenv guard) BASH_SOURCE is empty — that's NOT sourced, so we fall
# through to dispatch instead of trying to `return` at top-level.
[[ -n "${BASH_SOURCE[0]:-}" && "${BASH_SOURCE[0]}" != "${0}" ]] && return 0

# Parse global flags from anywhere in argv
# Allows: rc --dry-run up ., rc up --dry-run ., rc up . --dry-run
_remaining=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --output)
      if [[ "${2:-}" == "json" ]]; then
        OUTPUT_FORMAT="json"; shift 2
      else
        echo "Error: --output requires 'json'" >&2; exit 1
      fi
      ;;
    --dry-run) DRY_RUN=true; shift ;;
    --version|-V) echo "rc version ${RC_VERSION}"; exit 0 ;;
    *) _remaining+=("$1"); shift ;;
  esac
done
set -- "${_remaining[@]+"${_remaining[@]}"}"
unset _remaining

# Reject --dry-run on commands that don't support it
if [[ "$DRY_RUN" == "true" ]]; then
  case "${1:-}" in
    up|destroy|reload) ;;  # supported
    *)
      echo "Error: --dry-run is only supported for 'up', 'destroy', and 'reload'" >&2
      exit 1
      ;;
  esac
fi

# Reject --output json on commands that don't support it
if [[ "$OUTPUT_FORMAT" == "json" ]]; then
  case "${1:-}" in
    build|ls|up|down|destroy|test|doctor|auth|exec) ;;  # supported
    attach|schema|completions|setup|config|__bd-preflight-test|__bd-port-inject-test|"")
      echo "Error: --output json is not supported for '${1:-}' (use 'rc config show --json' for config JSON)" >&2
      exit 1
      ;;
  esac
fi

# Prerequisite checks — only where each tool is actually needed
# jq: required whenever --output json is in use
if [[ "$OUTPUT_FORMAT" == "json" ]]; then
  check_jq
fi

# Multiplexer binary prerequisites are checked by the baked provider hooks at
# runtime (rip-cage-61al.3 / ADR-005 D12). No host-side binary-presence check
# is performed here — the hook's own fail-loud handles any missing dependency.

# docker: needed for all commands that talk to Docker.
# `rc doctor --host` is the one exception: its job is to *diagnose* a wedged
# daemon, so the preflight (which would itself fail loud) must be skipped.
case "${1:-}" in
  build|up|ls|attach|exec|down|destroy|reload|test) check_docker ;;
  doctor)
    if [[ "${2:-}" != "--host" ]]; then
      check_docker
    fi
    ;;
esac

# Main dispatch
case "${1:-}" in
  build)    shift; cmd_build "$@" ;;
  up)       shift; cmd_up "$@" ;;
  ls)       shift; cmd_ls "$@" ;;
  attach)   shift; cmd_attach "$@" ;;
  exec)     shift; cmd_exec "$@" ;;
  down)     shift; cmd_down "$@" ;;
  destroy)  shift; cmd_destroy "$@" ;;
  reload)    shift; cmd_reload "$@" ;;
  allowlist) shift; cmd_allowlist "$@" ;;
  test)      shift; cmd_test "$@" ;;
  doctor)    shift; cmd_doctor "$@" ;;
  auth)      shift; cmd_auth "$@" ;;
  config)    shift; cmd_config "$@" ;;
  manifest)  shift; cmd_manifest "$@" ;;
  # completions: handled by fast-path above (before container guard); unreachable here
  completions) echo "Usage: rc completions <shell>" >&2; echo "Shells: zsh, bash" >&2; exit 1 ;;
  install)     shift; cmd_install "$@" ;;
  setup)       shift; cmd_setup "$@" ;;
  schema)  cmd_schema ;;
  __bd-preflight-test) shift; _bd_host_preflight "${1:-}" "${2:-}" --test-mode ;;
  __bd-port-inject-test) shift; _bd_dolt_port_inject_arg "${1:-}" ;;
  generate-dockerfile) shift; cmd_generate_dockerfile "$@" ;;
  *)       usage ;;
esac
