#!/usr/bin/env bash
set -euo pipefail

# Bail out if running inside a container — rc is a host-only tool
if [[ -f /.dockerenv ]]; then
  echo "Error: rc is a host tool — it manages containers from outside." >&2
  echo "You're already inside a rip-cage container. Run commands directly here." >&2
  exit 1
fi

IMAGE="rip-cage:latest"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

OUTPUT_FORMAT="human"
DRY_RUN=false

# Output helpers
json_error() {
  local msg="$1" code="$2"
  jq -nc --arg error "$msg" --arg code "$code" '{error: $error, code: $code}'
  exit 1
}
log() {
  if [[ "$OUTPUT_FORMAT" == "json" ]]; then
    echo "$@" >&2
  else
    echo "$@"
  fi
}

usage() {
  cat <<'EOF'
Usage: rc [--output json] [--dry-run] <command> [args]

Commands:
  build [docker-args...]                       Build the rip-cage image
  init [--force] [path]                        Scaffold .devcontainer/devcontainer.json
  up <path> [options]                           Start or resume a container
    --port PORT         Expose a port
    --env-file FILE     Load env vars from file
    --cpus N            CPU limit (default: 2)
    --memory SIZE       Memory limit (default: 4g)
    --pids-limit N      PID limit (default: 500)
  ls                                           List rip-cage containers
  attach [name]                                Attach to container tmux session
  down [name]                                  Stop a container
  destroy [name]                               Remove container and volumes
  test [name]                                  Run safety stack smoke test

Global flags:
  --output json    Emit machine-readable JSON (must precede subcommand)
  --dry-run        Preview what would happen without executing
EOF
  exit 1
}

cmd_build() {
  log "Building $IMAGE from ${SCRIPT_DIR}/Dockerfile..."
  if [[ "$OUTPUT_FORMAT" == "json" ]]; then
    if docker build -t "$IMAGE" "$@" "$SCRIPT_DIR" >/dev/null 2>&1; then
      jq -nc '{image: "rip-cage:latest", action: "built", status: "success"}'
    else
      json_error "Build failed" "BUILD_FAILED"
    fi
  else
    docker build -t "$IMAGE" "$@" "$SCRIPT_DIR"
  fi
}

cmd_init() {
  local force=0
  local target=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force=1; shift ;;
      *) target="$1"; shift ;;
    esac
  done

  if [[ -z "$target" ]]; then
    target="."
  fi

  # Resolve relative paths (including ".") to absolute before validation
  target=$(cd "$target" 2>/dev/null && pwd) || {
    echo "Error: $target does not exist or is not a directory" >&2
    return 1
  }
  validate_path "$target"
  target="$VALIDATED_PATH"

  local dest="${target}/.devcontainer/devcontainer.json"

  if [[ -f "$dest" ]] && [[ "$force" -eq 0 ]]; then
    echo "Error: ${dest} already exists. Use --force to overwrite." >&2
    return 1
  fi

  mkdir -p "${target}/.devcontainer"

  cat > "$dest" <<'DEVCONTAINER'
{
  "name": "Rip Cage",
  "image": "rip-cage:latest",
  "remoteUser": "agent",
  "mounts": [
    "source=rc-state-${devcontainerId},target=/home/agent/.claude-state,type=volume",
    "source=rc-history-${devcontainerId},target=/commandhistory,type=volume",
    "source=${localEnv:HOME}/.claude.json,target=/home/agent/.claude.json,type=bind",
    "source=${localEnv:HOME}/.claude/.credentials.json,target=/home/agent/.claude/.credentials.json,type=bind",
    "source=${localEnv:HOME}/.claude/CLAUDE.md,target=/home/agent/.rc-context/global-claude.md,type=bind,readonly",
    "source=${localEnv:HOME}/CLAUDE.md,target=/home/agent/.rc-context/home-claude.md,type=bind,readonly"
  ],
  "initializeCommand": "bash -c 'touch \"${HOME}/.claude/CLAUDE.md\" \"${HOME}/CLAUDE.md\" 2>/dev/null; if [[ \"$(uname)\" == \"Darwin\" ]]; then security find-generic-password -s \"Claude Code-credentials\" -w > \"${HOME}/.claude/.credentials.json\" 2>/dev/null || true; fi; true'",
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "BEADS_DOLT_SERVER_MODE": "1",
    "BEADS_DOLT_SERVER_HOST": "host.docker.internal"
  },
  "runArgs": ["--cpus=2", "--memory=4g", "--memory-swap=4g", "--pids-limit=500"],
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "postStartCommand": "/usr/local/bin/init-rip-cage.sh"
}
DEVCONTAINER

  echo "Created ${dest}"
}

# Derive container name from last two path components
container_name() {
  local path="$1"
  local parent
  parent=$(basename "$(dirname "$path")")
  local base
  base=$(basename "$path")
  echo "${parent}-${base}" | tr -cs 'a-zA-Z0-9_.-' '-' | sed 's/^-//' | sed 's/-$//'
}

validate_path() {
  local raw_path="$1"

  # Reject control characters. Null bytes can't survive bash arg passing,
  # but we check the visible range using POSIX character class.
  if [[ "$raw_path" =~ [[:cntrl:]] ]]; then
    [[ "$OUTPUT_FORMAT" == "json" ]] && json_error "Path contains invalid characters" "PATH_INVALID"
    echo "Error: path contains control characters" >&2
    exit 1
  fi

  # Must resolve to existing directory (realpath follows symlinks -- security-critical per ADR)
  local resolved
  if ! resolved=$(realpath "$raw_path" 2>/dev/null); then
    [[ "$OUTPUT_FORMAT" == "json" ]] && json_error "Path does not exist: $raw_path" "PATH_NOT_FOUND"
    echo "Error: $raw_path does not exist" >&2
    exit 1
  fi

  if [[ ! -d "$resolved" ]]; then
    [[ "$OUTPUT_FORMAT" == "json" ]] && json_error "Not a directory: $resolved" "PATH_INVALID"
    echo "Error: $resolved is not a directory" >&2
    exit 1
  fi

  # Check RC_ALLOWED_ROOTS is set
  if [[ -z "${RC_ALLOWED_ROOTS:-}" ]]; then
    [[ "$OUTPUT_FORMAT" == "json" ]] && json_error "RC_ALLOWED_ROOTS not set. Export as colon-separated absolute paths." "PATH_INVALID"
    echo "Error: RC_ALLOWED_ROOTS not set. Example: export RC_ALLOWED_ROOTS=\$HOME/code/personal:\$HOME/code/mapular" >&2
    exit 1
  fi

  # Check path is under an allowed root
  # IMPORTANT: Match exact root OR root/ prefix to prevent /code matching /code-evil.
  local allowed=false
  IFS=':' read -ra roots <<< "$RC_ALLOWED_ROOTS"
  for root in "${roots[@]}"; do
    local resolved_root
    resolved_root=$(realpath "$root" 2>/dev/null) || continue
    if [[ "$resolved" == "$resolved_root" ]] || [[ "$resolved" == "$resolved_root"/* ]]; then
      allowed=true
      break
    fi
  done

  if [[ "$allowed" == "false" ]]; then
    [[ "$OUTPUT_FORMAT" == "json" ]] && json_error "Path resolves outside allowed roots" "PATH_INVALID"
    echo "Error: $resolved is outside allowed roots ($RC_ALLOWED_ROOTS)" >&2
    exit 1
  fi

  # Return resolved path via VALIDATED_PATH global
  VALIDATED_PATH="$resolved"
}

cmd_up() {
  local path="" port="" env_file=""
  local rc_cpus="2" rc_memory="4g" rc_pids_limit="500"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --port) [[ $# -ge 2 ]] || { echo "Error: --port requires a value" >&2; exit 1; }; port="$2"; shift 2 ;;
      --env-file) [[ $# -ge 2 ]] || { echo "Error: --env-file requires a value" >&2; exit 1; }; env_file="$2"; shift 2 ;;
      --cpus) [[ $# -ge 2 ]] || { echo "Error: --cpus requires a value" >&2; exit 1; }; rc_cpus="$2"; shift 2 ;;
      --memory) [[ $# -ge 2 ]] || { echo "Error: --memory requires a value" >&2; exit 1; }; rc_memory="$2"; shift 2 ;;
      --pids-limit) [[ $# -ge 2 ]] || { echo "Error: --pids-limit requires a value" >&2; exit 1; }; rc_pids_limit="$2"; shift 2 ;;
      *) path="$1"; shift ;;
    esac
  done

  if [[ -z "$path" ]]; then
    [[ "$OUTPUT_FORMAT" == "json" ]] && json_error "path required. Usage: rc up <path>" "MISSING_ARGUMENT"
    echo "Error: path required. Usage: rc up <path> [--port PORT] [--env-file FILE]" >&2
    exit 1
  fi

  validate_path "$path"
  path="$VALIDATED_PATH"

  # Validate env-file early (before dry-run exit) to catch symlink bypasses
  if [[ -n "$env_file" ]]; then
    local resolved_env
    resolved_env=$(realpath "$env_file" 2>/dev/null) || {
      echo "Error: env file not found: $env_file" >&2; exit 1
    }
    validate_path "$(dirname "$resolved_env")"
    env_file="$resolved_env"
  fi

  # Check Docker
  if ! docker info > /dev/null 2>&1; then
    [[ "$OUTPUT_FORMAT" == "json" ]] && json_error "Docker is not running" "DOCKER_NOT_RUNNING"
    echo "Error: Docker is not running. Is OrbStack running?" >&2
    exit 1
  fi

  # Check image exists
  if ! docker image inspect "$IMAGE" > /dev/null 2>&1; then
    [[ "$OUTPUT_FORMAT" == "json" ]] && json_error "Image $IMAGE not found. Run: rc build" "IMAGE_NOT_FOUND"
    echo "Error: Image $IMAGE not found. Run: rc build" >&2
    exit 1
  fi

  local name_disambiguated=false

  local name
  name=$(container_name "$path")

  # Check for existing container
  local existing_path
  existing_path=$(docker inspect --format '{{ index .Config.Labels "rc.source.path" }}' "$name" 2>/dev/null || true)

  if [[ -n "$existing_path" ]]; then
    # Container exists
    if [[ "$existing_path" != "$path" ]]; then
      # Different path — disambiguate with hash suffix
      local hash
      hash=$(echo -n "$path" | shasum | cut -c1-4)
      name="${name}-${hash}"
      name_disambiguated=true
      log "Warning: container '$( container_name "$path" )' exists for different path. Using: $name"
    fi
  fi

  # Check container state
  local state
  state=$(docker inspect --format '{{.State.Status}}' "$name" 2>/dev/null || true)

  if [[ "$DRY_RUN" == "true" ]]; then
    local would_action
    if [[ "$state" == "running" ]]; then
      would_action="would_attach"
    elif [[ "$state" == "exited" ]] || [[ "$state" == "created" ]]; then
      would_action="would_resume"
    else
      would_action="would_create"
    fi

    if [[ "$OUTPUT_FORMAT" == "json" ]]; then
      jq -nc --arg name "$name" --arg action "$would_action" --arg source_path "$path" --argjson name_disambiguated "$name_disambiguated" --argjson dry_run true \
        '{dry_run: $dry_run, name: $name, action: $action, source_path: $source_path, name_disambiguated: $name_disambiguated}'
    else
      echo "Would ${would_action#would_} container $name for $path"
      echo "Would mount $path -> /workspace"
      [[ "$would_action" != "would_attach" ]] && echo "Would run init script"
    fi
    return 0
  fi

  if [[ "$state" == "running" ]]; then
    if [[ "$OUTPUT_FORMAT" == "json" ]]; then
      jq -nc --arg name "$name" --arg action "attached" --arg source_path "$path" --arg status "running" --argjson name_disambiguated "$name_disambiguated" \
        '{name: $name, action: $action, source_path: $source_path, status: $status, name_disambiguated: $name_disambiguated}'
      return
    fi
    echo "Container $name is already running. Attaching..."
    docker exec -it "$name" tmux new-session -A -s rip-cage
    return
  elif [[ "$state" == "exited" ]] || [[ "$state" == "created" ]]; then
    log "Resuming stopped container $name..."
    if [[ "$OUTPUT_FORMAT" == "json" ]]; then
      docker start "$name" >/dev/null
    else
      docker start "$name"
    fi
    local init_ok=true
    if [[ "$OUTPUT_FORMAT" == "json" ]]; then
      docker exec "$name" /usr/local/bin/init-rip-cage.sh >/dev/null 2>&1 || init_ok=false
    else
      docker exec "$name" /usr/local/bin/init-rip-cage.sh || init_ok=false
    fi
    if [[ "$init_ok" == "false" ]]; then
      if [[ "$OUTPUT_FORMAT" == "json" ]]; then
        docker stop "$name" >/dev/null 2>&1
        jq -nc --arg name "$name" --arg action "resumed" --arg source_path "$path" --arg status "stopped" --arg init "failed" --argjson name_disambiguated "$name_disambiguated" \
        '{name: $name, action: $action, source_path: $source_path, status: $status, init: $init, name_disambiguated: $name_disambiguated}'
        return 1
      fi
      echo "Error: init failed on resume. Stopping container so next 'rc up' retries." >&2
      docker stop "$name"
      exit 1
    fi
    if [[ "$OUTPUT_FORMAT" == "json" ]]; then
      jq -nc --arg name "$name" --arg action "resumed" --arg source_path "$path" --arg status "running" --arg init "success" --argjson name_disambiguated "$name_disambiguated" \
        '{name: $name, action: $action, source_path: $source_path, status: $status, init: $init, name_disambiguated: $name_disambiguated}'
      return
    fi
    docker exec -it "$name" tmux new-session -A -s rip-cage
    return
  fi

  # New container
  log "Creating container $name for $path..."
  local run_args=()
  run_args+=(-d --name "$name")
  run_args+=(--label "rc.source.path=$path")

  # Workspace mount
  run_args+=(-v "${path}:/workspace:delegated")

  # Extract OAuth credentials from macOS keychain to file (if on macOS)
  if [[ "$(uname)" == "Darwin" ]]; then
    security find-generic-password -s "Claude Code-credentials" -w > "${HOME}/.claude/.credentials.json" 2>/dev/null || true
  fi

  # D3: Credential health check — warn on expired or soon-to-expire tokens
  if [[ -s "${HOME}/.claude/.credentials.json" ]] && command -v jq &>/dev/null; then
    local expiry
    expiry=$(jq -r '.expiry // .expiresAt // empty' "${HOME}/.claude/.credentials.json" 2>/dev/null || true)
    if [[ -n "$expiry" ]]; then
      local expiry_epoch now_epoch
      expiry_epoch=$(date -jf "%Y-%m-%dT%H:%M:%S" "${expiry%%[.+Z]*}" "+%s" 2>/dev/null || date -d "$expiry" "+%s" 2>/dev/null || true)
      now_epoch=$(date "+%s")
      if [[ -n "$expiry_epoch" ]]; then
        local remaining=$(( expiry_epoch - now_epoch ))
        if [[ "$remaining" -lt 0 ]]; then
          echo "Warning: OAuth token is EXPIRED (expired $(( -remaining / 60 )) minutes ago)" >&2
          echo "  Run 'claude auth login' on the host to refresh, or set ANTHROPIC_API_KEY" >&2
        elif [[ "$remaining" -lt 600 ]]; then
          echo "Warning: OAuth token expires in $(( remaining / 60 )) minutes" >&2
          echo "  Consider running 'claude auth login' on the host to refresh" >&2
        fi
      fi
    fi
  fi

  # OAuth mounts (read-write, skip if missing to avoid Docker creating empty dirs)
  if [[ -f "${HOME}/.claude.json" ]]; then
    run_args+=(-v "${HOME}/.claude.json:/home/agent/.claude.json")
  else
    log "Warning: ${HOME}/.claude.json not found — skipping mount"
  fi
  if [[ -f "${HOME}/.claude/.credentials.json" ]]; then
    run_args+=(-v "${HOME}/.claude/.credentials.json:/home/agent/.claude/.credentials.json")
  else
    log "Warning: ${HOME}/.claude/.credentials.json not found — skipping mount (auth may not work)"
  fi

  # CLAUDE.md mounts (read-only, only if source exists)
  if [[ -f "${HOME}/.claude/CLAUDE.md" ]]; then
    run_args+=(-v "${HOME}/.claude/CLAUDE.md:/home/agent/.rc-context/global-claude.md:ro")
  fi
  if [[ -f "${HOME}/CLAUDE.md" ]]; then
    run_args+=(-v "${HOME}/CLAUDE.md:/home/agent/.rc-context/home-claude.md:ro")
  fi

  # Forward git identity from host
  local git_name git_email
  git_name=$(git config user.name 2>/dev/null || true)
  git_email=$(git config user.email 2>/dev/null || true)
  if [[ -n "$git_name" ]]; then
    run_args+=(-e "GIT_AUTHOR_NAME=${git_name}")
  fi
  if [[ -n "$git_email" ]]; then
    run_args+=(-e "GIT_AUTHOR_EMAIL=${git_email}")
  fi

  # State volumes
  run_args+=(-v "rc-state-${name}:/home/agent/.claude-state")
  run_args+=(-v "rc-history-${name}:/commandhistory")

  # Optional flags
  if [[ -n "$port" ]]; then
    run_args+=(-p "${port}:${port}")
  fi
  if [[ -n "$env_file" ]]; then
    run_args+=(--env-file "$env_file")
  fi

  # Resource limits (D2)
  run_args+=(--cpus="$rc_cpus" --memory="$rc_memory" --memory-swap="$rc_memory" --pids-limit="$rc_pids_limit")

  # Enable host.docker.internal on Linux Docker Engine (no-op on macOS where it exists natively)
  run_args+=(--add-host=host.docker.internal:host-gateway)

  # Beads: connect container's bd to host's Dolt server (avoids database lock conflict)
  run_args+=(-e "BEADS_DOLT_SERVER_MODE=1")
  run_args+=(-e "BEADS_DOLT_SERVER_HOST=host.docker.internal")
  local dolt_port_file="${path}/.beads/dolt-server.port"
  if [[ -f "$dolt_port_file" ]]; then
    run_args+=(-e "BEADS_DOLT_SERVER_PORT=$(cat "$dolt_port_file")")
  fi

  run_args+=("$IMAGE" sleep infinity)

  if [[ "$OUTPUT_FORMAT" == "json" ]]; then
    local docker_stderr
    if ! docker_stderr=$(docker run "${run_args[@]}" 2>&1 >/dev/null); then
      if echo "$docker_stderr" | grep -q "is already in use by container"; then
        json_error "Container name $name is already in use" "NAME_CONFLICT"
      fi
      json_error "Failed to create container $name" "DOCKER_ERROR"
    fi
  else
    docker run "${run_args[@]}"
  fi
  log "Running init script..."
  local init_ok=true
  if [[ "$OUTPUT_FORMAT" == "json" ]]; then
    docker exec "$name" /usr/local/bin/init-rip-cage.sh >/dev/null 2>&1 || init_ok=false
  else
    docker exec "$name" /usr/local/bin/init-rip-cage.sh || init_ok=false
  fi
  if [[ "$init_ok" == "false" ]]; then
    if [[ "$OUTPUT_FORMAT" == "json" ]]; then
      docker stop "$name" >/dev/null 2>&1
      jq -nc --arg name "$name" --arg action "created" --arg source_path "$path" --arg status "stopped" --arg init "failed" --argjson name_disambiguated "$name_disambiguated" \
        '{name: $name, action: $action, source_path: $source_path, status: $status, init: $init, name_disambiguated: $name_disambiguated}'
      return 1
    fi
    echo "Error: init failed. Stopping container so next 'rc up' retries." >&2
    docker stop "$name"
    exit 1
  fi
  if [[ "$OUTPUT_FORMAT" == "json" ]]; then
    jq -nc --arg name "$name" --arg action "created" --arg source_path "$path" --arg status "running" --arg init "success" --argjson name_disambiguated "$name_disambiguated" \
      '{name: $name, action: $action, source_path: $source_path, status: $status, init: $init, name_disambiguated: $name_disambiguated}'
    return
  fi
  docker exec -it "$name" tmux new-session -A -s rip-cage
}

cmd_ls() {
  if [[ "$OUTPUT_FORMAT" == "json" ]]; then
    docker ps -a --filter label=rc.source.path --format '{{.Names}}\t{{.State}}\t{{.Status}}\t{{.Label "rc.source.path"}}' | \
      jq -Rsn '[inputs | rtrimstr("\n") | select(length > 0) | split("\t") | {name: .[0], status: .[1], uptime: .[2], source_path: .[3]}]'
  else
    docker ps -a --filter label=rc.source.path --format "table {{.Names}}\t{{.Status}}\t{{.Label \"rc.source.path\"}}"
  fi
}

resolve_name() {
  local name="${1:-}"
  if [[ -n "$name" ]]; then
    echo "$name"
    return
  fi
  local containers
  if ! containers=$(docker ps -a --filter label=rc.source.path --format '{{.Names}}'); then
    echo "Error: failed to list containers (is Docker running?)" >&2
    return 1
  fi
  local count
  count=$(echo "$containers" | grep -c . || true)
  if [[ "$count" -eq 0 ]]; then
    echo "Error: no rip-cage containers found." >&2
    return 1
  elif [[ "$count" -eq 1 ]]; then
    echo "$containers"
    return
  else
    echo "Error: multiple containers — specify a name:" >&2
    echo "$containers" >&2
    return 1
  fi
}

cmd_attach() {
  local name
  name=$(resolve_name "${1:-}") || exit 1
  docker exec -it "$name" tmux new-session -A -s rip-cage
}

verify_rc_container() {
  local name="$1"
  local label
  label=$(docker inspect --format '{{ index .Config.Labels "rc.source.path" }}' "$name" 2>/dev/null || true)
  if [[ -z "$label" ]]; then
    [[ "$OUTPUT_FORMAT" == "json" ]] && json_error "Container $name is not managed by rc" "CONTAINER_NOT_FOUND"
    echo "Error: container $name is not managed by rc" >&2
    exit 1
  fi
}

cmd_down() {
  local name
  name=$(resolve_name "${1:-}") || exit 1
  local state
  state=$(docker inspect --format '{{.State.Status}}' "$name" 2>/dev/null || true)
  if [[ -z "$state" ]]; then
    [[ "$OUTPUT_FORMAT" == "json" ]] && json_error "Container not found: $name" "CONTAINER_NOT_FOUND"
    echo "Error: container $name not found" >&2; exit 1
  fi
  verify_rc_container "$name"
  if [[ "$state" != "running" ]]; then
    [[ "$OUTPUT_FORMAT" == "json" ]] && json_error "Container $name is not running (state: $state)" "CONTAINER_NOT_RUNNING"
    echo "Error: container $name is not running (state: $state)" >&2; exit 1
  fi
  docker stop "$name" >/dev/null 2>&1
  if [[ "$OUTPUT_FORMAT" == "json" ]]; then
    jq -nc --arg name "$name" --arg action "stopped" --arg status "exited" \
      '{name: $name, action: $action, status: $status}'
  else
    echo "Container $name stopped."
  fi
}

cmd_destroy() {
  local name
  name=$(resolve_name "${1:-}") || exit 1

  # Verify container exists and is managed by rc
  if ! docker inspect "$name" >/dev/null 2>&1; then
    [[ "$OUTPUT_FORMAT" == "json" ]] && json_error "Container not found: $name" "CONTAINER_NOT_FOUND"
    echo "Error: container $name not found" >&2; exit 1
  fi
  verify_rc_container "$name"

  if [[ "$DRY_RUN" == "true" ]]; then
    if [[ "$OUTPUT_FORMAT" == "json" ]]; then
      jq -nc --arg name "$name" --arg action "would_destroy" --argjson dry_run true \
        --arg vol1 "rc-state-$name" --arg vol2 "rc-history-$name" \
        '{dry_run: $dry_run, name: $name, action: $action, volumes_removed: [$vol1, $vol2]}'
    else
      echo "Would remove container $name"
      echo "Would remove volumes: rc-state-$name, rc-history-$name"
    fi
    return 0
  fi

  if ! docker rm -f "$name" >/dev/null 2>&1; then
    [[ "$OUTPUT_FORMAT" == "json" ]] && json_error "Container not found: $name" "CONTAINER_NOT_FOUND"
    echo "Error: container $name not found" >&2; exit 1
  fi
  local volumes_removed=()
  for vol in "rc-state-${name}" "rc-history-${name}"; do
    if [[ "$OUTPUT_FORMAT" == "json" ]]; then
      if docker volume rm "$vol" >/dev/null 2>/dev/null; then
        volumes_removed+=("$vol")
      fi
    else
      if docker volume rm "$vol" 2>/dev/null; then
        volumes_removed+=("$vol")
      else
        echo "Warning: volume $vol not found"
      fi
    fi
  done
  if [[ "$OUTPUT_FORMAT" == "json" ]]; then
    local vol_json
    if [[ ${#volumes_removed[@]} -eq 0 ]]; then
      vol_json="[]"
    else
      vol_json=$(printf '%s\n' "${volumes_removed[@]}" | jq -R 'select(length > 0)' | jq -sc .)
    fi
    jq -nc --arg name "$name" --arg action "destroyed" --argjson volumes_removed "$vol_json" \
      '{name: $name, action: $action, volumes_removed: $volumes_removed}'
  else
    echo "Container $name and volumes destroyed."
  fi
}

cmd_test() {
  local name
  name=$(resolve_name "${1:-}") || exit 1
  verify_rc_container "$name"
  if [[ "$OUTPUT_FORMAT" == "json" ]]; then
    local output
    output=$(docker exec "$name" /usr/local/lib/rip-cage/test-safety-stack.sh 2>&1) || true
    # Parse PASS/FAIL lines into JSON array
    local checks="[]" overall="pass"
    while IFS= read -r line; do
      if [[ "$line" =~ ^(PASS|FAIL)[[:space:]]+\[([0-9]+)\][[:space:]]+(.*) ]]; then
        local status="${BASH_REMATCH[1],,}"  # lowercase
        local idx="${BASH_REMATCH[2]}"
        local desc="${BASH_REMATCH[3]}"
        local test_name
        test_name=$(echo "$desc" | sed 's/ — .*//')
        local detail=""
        if [[ "$desc" == *" — "* ]]; then
          detail="${desc#* — }"
        fi
        checks=$(echo "$checks" | jq --arg name "$test_name" --arg status "$status" --arg detail "$detail" \
          '. + [{name: $name, status: $status, detail: $detail}]')
        [[ "$status" == "fail" ]] && overall="fail"
      fi
    done <<< "$output"
    jq -nc --arg name "$name" --argjson checks "$checks" --arg overall "$overall" \
      '{name: $name, checks: $checks, overall: $overall}'
  else
    docker exec "$name" /usr/local/lib/rip-cage/test-safety-stack.sh
  fi
}

cmd_schema() {
  cat <<'SCHEMA'
{
  "version": "1",
  "commands": {
    "up": {
      "args": [{"name": "path", "type": "path", "required": true}],
      "flags": {
        "--output": {"values": ["json"], "default": null},
        "--dry-run": {"type": "bool", "default": false},
        "--env-file": {"type": "path", "optional": true},
        "--port": {"type": "string", "optional": true},
        "--cpus": {"type": "string", "default": "2"},
        "--memory": {"type": "string", "default": "4g"},
        "--pids-limit": {"type": "string", "default": "500"}
      }
    },
    "down": {
      "args": [{"name": "name", "type": "string", "required": false, "note": "auto-selected if exactly one container exists"}],
      "flags": {"--output": {"values": ["json"], "default": null}}
    },
    "destroy": {
      "args": [{"name": "name", "type": "string", "required": false}],
      "flags": {
        "--output": {"values": ["json"], "default": null},
        "--dry-run": {"type": "bool", "default": false}
      }
    },
    "ls": {
      "args": [],
      "flags": {"--output": {"values": ["json"], "default": null}}
    },
    "test": {
      "args": [{"name": "name", "type": "string", "required": false}],
      "flags": {"--output": {"values": ["json"], "default": null}}
    },
    "attach": {
      "args": [{"name": "name", "type": "string", "required": false}],
      "flags": {}
    },
    "build": {
      "args": [],
      "flags": {"--output": {"values": ["json"], "default": null}}
    },
    "init": {
      "args": [{"name": "path", "type": "path", "required": true}],
      "flags": {"--force": {"type": "bool", "default": false}}
    },
    "schema": {
      "args": [],
      "flags": {}
    }
  }
}
SCHEMA
}

# Parse global flags
while [[ $# -gt 0 ]]; do
  case "$1" in
    --output)
      if [[ "${2:-}" == "json" ]]; then
        OUTPUT_FORMAT="json"; shift 2
      else
        echo "Error: --output requires 'json'" >&2; exit 1
      fi
      ;;
    --dry-run) DRY_RUN=true; shift ;;
    *) break ;;  # first non-flag arg is the subcommand
  esac
done

# Reject --dry-run on commands that don't support it
if [[ "$DRY_RUN" == "true" ]]; then
  case "${1:-}" in
    up|destroy) ;;  # supported
    *)
      echo "Error: --dry-run is only supported for 'up' and 'destroy'" >&2
      exit 1
      ;;
  esac
fi

# Reject --output json on commands that don't support it
if [[ "$OUTPUT_FORMAT" == "json" ]]; then
  case "${1:-}" in
    build|ls|up|down|destroy|test) ;;  # supported
    init|attach|schema)
      echo "Error: --output json is not supported for '${1:-}'" >&2
      exit 1
      ;;
  esac
fi

# Main dispatch
case "${1:-}" in
  build)   shift; cmd_build "$@" ;;
  init)    shift; cmd_init "$@" ;;
  up)      shift; cmd_up "$@" ;;
  ls)      shift; cmd_ls "$@" ;;
  attach)  shift; cmd_attach "$@" ;;
  down)    shift; cmd_down "$@" ;;
  destroy) shift; cmd_destroy "$@" ;;
  test)    shift; cmd_test "$@" ;;
  schema)  cmd_schema ;;
  *)       usage ;;
esac
