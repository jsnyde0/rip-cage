#!/usr/bin/env bash
# Apply strict mode only when executed, not when sourced by a test harness.
# Mirror the dispatch-skip predicate at the bottom of this file (rc:9482) so the
# two stay in sync. Piped exec (`bash -s --`, BASH_SOURCE empty) counts as invoked.
if ! { [[ -n "${BASH_SOURCE[0]:-}" && "${BASH_SOURCE[0]}" != "${0}" ]]; }; then
  set -euo pipefail
fi

# Resolve SCRIPT_DIR through symlinks so `rc build` finds the Dockerfile
# even when rc is invoked via a symlink (e.g., /usr/local/bin/rc -> .../rip-cage/rc)
#
# Uses ${BASH_SOURCE[0]:-$0}, not bare $0 (rip-cage-gto1 decomposition fix):
# for DIRECT or symlinked invocation, BASH_SOURCE[0] names rc's own path, same
# as $0 would -- a no-op there. It differs in two cases: (1) when rc is
# SOURCED from another script, $0 is the SOURCING script's own path, not
# rc's -- this used to be harmless (SCRIPT_DIR was only dereferenced inside
# functions at call time) but became load-bearing once the shim itself needs
# a correct SCRIPT_DIR to `source` cli/lib + cli/ modules at SOURCE time
# (rc:cli-module-sourcing below); and (2) under `bash -s --` piped-exec,
# BASH_SOURCE is empty so this falls back to $0="bash" -- dirname "bash" is
# ".", so SCRIPT_DIR resolves to the CALLER'S CWD, not rc's own directory.
# Piped-exec callers (e.g. tests/test-auth-refresh.sh's run_rc) must cd to
# the repo root themselves before piping if they need SCRIPT_DIR correct.
# BASH_SOURCE[0] always names the file bash is currently reading (rc's own
# path) when reading from a real file; it is empty when reading from stdin.
_resolve_script_dir() {
  local source="${BASH_SOURCE[0]:-$0}"
  while [[ -L "$source" ]]; do
    local dir
    dir="$(cd "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    # If readlink returned a relative path, resolve it against the link's dir
    [[ "$source" != /* ]] && source="$dir/$source"
  done
  cd "$(dirname "$source")" && pwd
}
SCRIPT_DIR="$(_resolve_script_dir)"

# Fast-path: completions dispatch — canonical handler for `rc completions`.
# Must run before the container guard so shell startup (eval "$(rc completions zsh)")
# works inside containers and CI. Pure-output command; no Docker dependency.
# Keeps shell startup overhead to ~5-10ms (symlink resolution + cat)
if [[ "${1:-}" == "completions" ]]; then
  shift
  case "${1:-}" in
    zsh)  cat "${SCRIPT_DIR}/completions/_rc"; exit 0 ;;
    bash) cat "${SCRIPT_DIR}/completions/rc.bash"; exit 0 ;;
    "")   echo "Usage: rc completions <shell>" >&2; echo "Shells: zsh, bash" >&2; exit 1 ;;
    *)    echo "Error: unknown shell '${1}'. Supported: zsh, bash" >&2; exit 1 ;;
  esac
fi

# Bail out if running inside a container — rc is a host-only tool
if [[ -f /.dockerenv ]]; then
  echo "Error: rc is a host tool — it manages containers from outside." >&2
  echo "You're already inside a rip-cage container. Run commands directly here." >&2
  exit 1
fi

# shellcheck disable=SC2034
# IMAGE is read throughout cli/up.sh + cli/build.sh -- shellcheck can't follow
# the loop-based dynamic `source` below (hence the SC1090 disable there), so
# it can no longer see those cross-file reads and flags this as unused.
IMAGE="${RC_IMAGE:-rip-cage:latest}"

# GHCR registry for pre-built images (ADR-008 D6, implemented at v0.2.0).
# `${VAR-default}` (no colon) honors explicit empty as "skip pull, build locally" —
# useful for local Dockerfile dev. Unset uses the default.
RIP_CAGE_IMAGE_REGISTRY="${RIP_CAGE_IMAGE_REGISTRY-ghcr.io/jsnyde0/rip-cage}"

# Load config file if present (sets defaults for RC_ALLOWED_ROOTS, etc.)
# Config location: ~/.config/rip-cage/rc.conf or $RC_CONFIG
_rc_conf="${RC_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/rip-cage/rc.conf}"
if [[ -f "$_rc_conf" ]]; then
  # shellcheck source=/dev/null
  source "$_rc_conf"
fi
unset _rc_conf

OUTPUT_FORMAT="human"
DRY_RUN=false
# shellcheck disable=SC2034
# RC_VALIDATE_WARNING is written by validate_path (cli/lib/path.sh) and read
# by cmd_up (cli/up.sh) -- same cross-file-shellcheck-can't-follow reason as
# IMAGE above.
RC_VALIDATE_WARNING=""

RC_VERSION="$(cat "${SCRIPT_DIR}/VERSION" 2>/dev/null || echo "unknown")"


# Source shared helpers (cli/lib/) then verb modules (cli/) -- decomposed out
# of this file (rip-cage-gto1). MUST happen before the "sourced vs invoked"
# dispatch-skip predicate below, so that a test harness sourcing `rc` (as
# tests/*.sh do, to call functions directly without triggering dispatch) gets
# every function + top-level global defined, exactly as when this was one
# flat file. None of the sourced files set -euo pipefail themselves -- this
# shim is the ONLY place strict mode is toggled (map hazard 2); it is owned
# here, once, so sourcing a module never leaks -e onto the caller.
for _rc_lib in output docker container path config manifest_checks; do
  # shellcheck disable=SC1090
  source "${SCRIPT_DIR}/cli/lib/${_rc_lib}.sh"
done
unset _rc_lib

for _rc_mod in build up ls attach_exec down_destroy reload allowlist test doctor setup manifest config auth install_schema; do
  # shellcheck disable=SC1090
  source "${SCRIPT_DIR}/cli/${_rc_mod}.sh"
done
unset _rc_mod


# When sourced (e.g., by tests), skip dispatch — expose functions only.
# BASH_SOURCE[0] is the script file; $0 is the invoking shell when sourced.
# When piped via `bash -s --` (test-auth-refresh.sh's run_rc, to bypass the
# /.dockerenv guard) BASH_SOURCE is empty — that's NOT sourced, so we fall
# through to dispatch instead of trying to `return` at top-level.
[[ -n "${BASH_SOURCE[0]:-}" && "${BASH_SOURCE[0]}" != "${0}" ]] && return 0

# Parse global flags from anywhere in argv
# Allows: rc --dry-run up ., rc up --dry-run ., rc up . --dry-run
_remaining=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --output)
      if [[ "${2:-}" == "json" ]]; then
        OUTPUT_FORMAT="json"; shift 2
      else
        echo "Error: --output requires 'json'" >&2; exit 1
      fi
      ;;
    --dry-run) DRY_RUN=true; shift ;;
    --version|-V) echo "rc version ${RC_VERSION}"; exit 0 ;;
    *) _remaining+=("$1"); shift ;;
  esac
done
set -- "${_remaining[@]+"${_remaining[@]}"}"
unset _remaining

# Reject --dry-run on commands that don't support it
if [[ "$DRY_RUN" == "true" ]]; then
  case "${1:-}" in
    up|destroy|reload) ;;  # supported
    *)
      echo "Error: --dry-run is only supported for 'up', 'destroy', and 'reload'" >&2
      exit 1
      ;;
  esac
fi

# Reject --output json on commands that don't support it
if [[ "$OUTPUT_FORMAT" == "json" ]]; then
  case "${1:-}" in
    build|ls|up|down|destroy|test|doctor|auth|exec) ;;  # supported
    attach|schema|completions|setup|config|__bd-preflight-test|__bd-port-inject-test|"")
      echo "Error: --output json is not supported for '${1:-}' (use 'rc config show --json' for config JSON)" >&2
      exit 1
      ;;
  esac
fi

# Prerequisite checks — only where each tool is actually needed
# jq: required whenever --output json is in use
if [[ "$OUTPUT_FORMAT" == "json" ]]; then
  check_jq
fi

# Multiplexer binary prerequisites are checked by the baked provider hooks at
# runtime (rip-cage-61al.3 / ADR-005 D12). No host-side binary-presence check
# is performed here — the hook's own fail-loud handles any missing dependency.

# docker: needed for all commands that talk to Docker.
# `rc doctor --host` is the one exception: its job is to *diagnose* a wedged
# daemon, so the preflight (which would itself fail loud) must be skipped.
case "${1:-}" in
  build|up|ls|attach|exec|down|destroy|reload|test) check_docker ;;
  doctor)
    if [[ "${2:-}" != "--host" ]]; then
      check_docker
    fi
    ;;
esac

# Main dispatch
case "${1:-}" in
  build)    shift; cmd_build "$@" ;;
  up)       shift; cmd_up "$@" ;;
  ls)       shift; cmd_ls "$@" ;;
  attach)   shift; cmd_attach "$@" ;;
  exec)     shift; cmd_exec "$@" ;;
  down)     shift; cmd_down "$@" ;;
  destroy)  shift; cmd_destroy "$@" ;;
  reload)    shift; cmd_reload "$@" ;;
  allowlist) shift; cmd_allowlist "$@" ;;
  test)      shift; cmd_test "$@" ;;
  doctor)    shift; cmd_doctor "$@" ;;
  auth)      shift; cmd_auth "$@" ;;
  config)    shift; cmd_config "$@" ;;
  manifest)  shift; cmd_manifest "$@" ;;
  # completions: handled by fast-path above (before container guard); unreachable here
  completions) echo "Usage: rc completions <shell>" >&2; echo "Shells: zsh, bash" >&2; exit 1 ;;
  install)     shift; cmd_install "$@" ;;
  setup)       shift; cmd_setup "$@" ;;
  schema)  cmd_schema ;;
  __bd-preflight-test) shift; _bd_host_preflight "${1:-}" "${2:-}" --test-mode ;;
  __bd-port-inject-test) shift; _bd_dolt_port_inject_arg "${1:-}" ;;
  generate-dockerfile) shift; cmd_generate_dockerfile "$@" ;;
  *)       usage ;;
esac
