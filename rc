#!/usr/bin/env bash
set -euo pipefail

IMAGE="rip-cage:latest"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

OUTPUT_FORMAT="human"
DRY_RUN=false

# Output helpers
json_out() { echo "$1" | jq -c .; }
json_error() {
  local msg="$1" code="$2"
  echo "{\"error\":\"$msg\",\"code\":\"$code\"}" | jq -c . >&1
  exit 1
}
log() {
  if [[ "$OUTPUT_FORMAT" == "json" ]]; then
    echo "$@" >&2
  else
    echo "$@"
  fi
}

usage() {
  cat <<'EOF'
Usage: rc [--output json] [--dry-run] <command> [args]

Commands:
  build [docker-args...]                       Build the rip-cage image
  init [--force] [path]                        Scaffold .devcontainer/devcontainer.json
  up <path> [--port PORT] [--env-file FILE]    Start or resume a container
  ls                                           List rip-cage containers
  attach <name>                                Attach to container tmux session
  down <name>                                  Stop a container
  destroy <name>                               Remove container and volumes
  test <name>                                  Run safety stack smoke test

Global flags:
  --output json    Emit machine-readable JSON (must precede subcommand)
  --dry-run        Preview what would happen without executing
EOF
  exit 1
}

cmd_build() {
  log "Building $IMAGE from ${SCRIPT_DIR}/Dockerfile..."
  if [[ "$OUTPUT_FORMAT" == "json" ]]; then
    if docker build -t "$IMAGE" "$@" "$SCRIPT_DIR" >/dev/null 2>&1; then
      json_out '{"image":"rip-cage:latest","action":"built","status":"success"}'
    else
      json_error "Build failed" "BUILD_FAILED"
    fi
  else
    docker build -t "$IMAGE" "$@" "$SCRIPT_DIR"
  fi
}

cmd_init() {
  local force=0
  local target=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force=1; shift ;;
      *) target="$1"; shift ;;
    esac
  done

  if [[ -z "$target" ]]; then
    target="."
  fi

  local dest="${target}/.devcontainer/devcontainer.json"

  if [[ -f "$dest" ]] && [[ "$force" -eq 0 ]]; then
    echo "Error: ${dest} already exists. Use --force to overwrite." >&2
    return 1
  fi

  mkdir -p "${target}/.devcontainer"

  cat > "$dest" <<'DEVCONTAINER'
{
  "name": "Rip Cage",
  "image": "rip-cage:latest",
  "remoteUser": "agent",
  "mounts": [
    "source=rc-state-${devcontainerId},target=/home/agent/.claude-state,type=volume",
    "source=rc-history-${devcontainerId},target=/commandhistory,type=volume",
    "source=${localEnv:HOME}/.claude.json,target=/home/agent/.claude.json,type=bind",
    "source=${localEnv:HOME}/.claude/.credentials.json,target=/home/agent/.claude/.credentials.json,type=bind",
    "source=${localEnv:HOME}/.claude/CLAUDE.md,target=/home/agent/.rc-context/global-claude.md,type=bind,readonly",
    "source=${localEnv:HOME}/CLAUDE.md,target=/home/agent/.rc-context/home-claude.md,type=bind,readonly"
  ],
  "initializeCommand": "bash -c 'touch \"${HOME}/.claude/CLAUDE.md\" \"${HOME}/CLAUDE.md\" 2>/dev/null; if [[ \"$(uname)\" == \"Darwin\" ]]; then security find-generic-password -s \"Claude Code-credentials\" -w > \"${HOME}/.claude/.credentials.json\" 2>/dev/null || true; fi; true'",
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "postStartCommand": "/usr/local/bin/init-rip-cage.sh"
}
DEVCONTAINER

  echo "Created ${dest}"
}

# Derive container name from last two path components
container_name() {
  local path="$1"
  local parent
  parent=$(basename "$(dirname "$path")")
  local base
  base=$(basename "$path")
  echo "${parent}-${base}" | tr -cs 'a-zA-Z0-9_.-' '-' | sed 's/^-//' | sed 's/-$//'
}

cmd_up() {
  local path="" port="" env_file=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --port) port="$2"; shift 2 ;;
      --env-file) env_file="$2"; shift 2 ;;
      *) path="$1"; shift ;;
    esac
  done

  if [[ -z "$path" ]]; then
    [[ "$OUTPUT_FORMAT" == "json" ]] && json_error "path required. Usage: rc up <path>" "MISSING_ARGUMENT"
    echo "Error: path required. Usage: rc up <path> [--port PORT] [--env-file FILE]" >&2
    exit 1
  fi

  path=$(realpath "$path")
  if [[ ! -d "$path" ]]; then
    echo "Error: $path does not exist or is not a directory" >&2
    exit 1
  fi

  # Check Docker
  if ! docker info > /dev/null 2>&1; then
    [[ "$OUTPUT_FORMAT" == "json" ]] && json_error "Docker is not running" "DOCKER_NOT_RUNNING"
    echo "Error: Docker is not running. Is OrbStack running?" >&2
    exit 1
  fi

  # Check image exists
  if ! docker image inspect "$IMAGE" > /dev/null 2>&1; then
    [[ "$OUTPUT_FORMAT" == "json" ]] && json_error "Image $IMAGE not found. Run: rc build" "IMAGE_NOT_FOUND"
    echo "Error: Image $IMAGE not found. Run: rc build" >&2
    exit 1
  fi

  local name_disambiguated=false

  local name
  name=$(container_name "$path")

  # Check for existing container
  local existing_path
  existing_path=$(docker inspect --format '{{ index .Config.Labels "rc.source.path" }}' "$name" 2>/dev/null || true)

  if [[ -n "$existing_path" ]]; then
    # Container exists
    if [[ "$existing_path" != "$path" ]]; then
      # Different path — disambiguate with hash suffix
      local hash
      hash=$(echo -n "$path" | shasum | cut -c1-4)
      name="${name}-${hash}"
      name_disambiguated=true
      log "Warning: container '$( container_name "$path" )' exists for different path. Using: $name"
    fi
  fi

  # Check container state
  local state
  state=$(docker inspect --format '{{.State.Status}}' "$name" 2>/dev/null || true)

  if [[ "$state" == "running" ]]; then
    if [[ "$OUTPUT_FORMAT" == "json" ]]; then
      json_out "{\"name\":\"$name\",\"action\":\"attached\",\"source_path\":\"$path\",\"status\":\"running\",\"name_disambiguated\":$name_disambiguated}"
      return
    fi
    echo "Container $name is already running. Attaching..."
    docker exec -it "$name" tmux new-session -A -s rip-cage
    return
  elif [[ "$state" == "exited" ]] || [[ "$state" == "created" ]]; then
    log "Resuming stopped container $name..."
    docker start "$name"
    if ! docker exec "$name" /usr/local/bin/init-rip-cage.sh; then
      if [[ "$OUTPUT_FORMAT" == "json" ]]; then
        docker stop "$name" >/dev/null 2>&1
        json_out "{\"name\":\"$name\",\"action\":\"resumed\",\"source_path\":\"$path\",\"status\":\"stopped\",\"init\":\"failed\",\"name_disambiguated\":$name_disambiguated}"
        return
      fi
      echo "Error: init failed on resume. Stopping container so next 'rc up' retries." >&2
      docker stop "$name"
      exit 1
    fi
    if [[ "$OUTPUT_FORMAT" == "json" ]]; then
      json_out "{\"name\":\"$name\",\"action\":\"resumed\",\"source_path\":\"$path\",\"status\":\"running\",\"init\":\"success\",\"name_disambiguated\":$name_disambiguated}"
      return
    fi
    docker exec -it "$name" tmux new-session -A -s rip-cage
    return
  fi

  # New container
  log "Creating container $name for $path..."
  local run_args=()
  run_args+=(-d --name "$name")
  run_args+=(--label "rc.source.path=$path")

  # Workspace mount
  run_args+=(-v "${path}:/workspace:delegated")

  # Extract OAuth credentials from macOS keychain to file (if on macOS)
  if [[ "$(uname)" == "Darwin" ]]; then
    security find-generic-password -s "Claude Code-credentials" -w > "${HOME}/.claude/.credentials.json" 2>/dev/null || true
  fi

  # OAuth mounts (read-write, skip if missing to avoid Docker creating empty dirs)
  if [[ -f "${HOME}/.claude.json" ]]; then
    run_args+=(-v "${HOME}/.claude.json:/home/agent/.claude.json")
  else
    echo "Warning: ${HOME}/.claude.json not found — skipping mount"
  fi
  if [[ -f "${HOME}/.claude/.credentials.json" ]]; then
    run_args+=(-v "${HOME}/.claude/.credentials.json:/home/agent/.claude/.credentials.json")
  else
    echo "Warning: ${HOME}/.claude/.credentials.json not found — skipping mount (auth may not work)"
  fi

  # CLAUDE.md mounts (read-only, only if source exists)
  if [[ -f "${HOME}/.claude/CLAUDE.md" ]]; then
    run_args+=(-v "${HOME}/.claude/CLAUDE.md:/home/agent/.rc-context/global-claude.md:ro")
  fi
  if [[ -f "${HOME}/CLAUDE.md" ]]; then
    run_args+=(-v "${HOME}/CLAUDE.md:/home/agent/.rc-context/home-claude.md:ro")
  fi

  # Forward git identity from host
  local git_name git_email
  git_name=$(git config user.name 2>/dev/null || true)
  git_email=$(git config user.email 2>/dev/null || true)
  if [[ -n "$git_name" ]]; then
    run_args+=(-e "GIT_AUTHOR_NAME=${git_name}")
  fi
  if [[ -n "$git_email" ]]; then
    run_args+=(-e "GIT_AUTHOR_EMAIL=${git_email}")
  fi

  # State volumes
  run_args+=(-v "rc-state-${name}:/home/agent/.claude-state")
  run_args+=(-v "rc-history-${name}:/commandhistory")

  # Optional flags
  if [[ -n "$port" ]]; then
    run_args+=(-p "${port}:${port}")
  fi
  if [[ -n "$env_file" ]]; then
    run_args+=(--env-file "$env_file")
  fi

  run_args+=("$IMAGE" sleep infinity)

  docker run "${run_args[@]}"
  log "Running init script..."
  if ! docker exec "$name" /usr/local/bin/init-rip-cage.sh; then
    if [[ "$OUTPUT_FORMAT" == "json" ]]; then
      docker stop "$name" >/dev/null 2>&1
      json_out "{\"name\":\"$name\",\"action\":\"created\",\"source_path\":\"$path\",\"status\":\"stopped\",\"init\":\"failed\",\"name_disambiguated\":$name_disambiguated}"
      return
    fi
    echo "Error: init failed. Stopping container so next 'rc up' retries." >&2
    docker stop "$name"
    exit 1
  fi
  if [[ "$OUTPUT_FORMAT" == "json" ]]; then
    json_out "{\"name\":\"$name\",\"action\":\"created\",\"source_path\":\"$path\",\"status\":\"running\",\"init\":\"success\",\"name_disambiguated\":$name_disambiguated}"
    return
  fi
  docker exec -it "$name" tmux new-session -A -s rip-cage
}

cmd_ls() {
  if [[ "$OUTPUT_FORMAT" == "json" ]]; then
    docker ps -a --filter label=rc.source.path --format '{{.Names}}\t{{.Status}}\t{{.Label "rc.source.path"}}' | \
      jq -Rsn '[inputs | rtrimstr("\n") | split("\t") | {name: .[0], status: .[1], source_path: .[2]}]'
  else
    docker ps -a --filter label=rc.source.path --format "table {{.Names}}\t{{.Status}}\t{{.Label \"rc.source.path\"}}"
  fi
}

cmd_attach() {
  local name="${1:?Error: name required. Usage: rc attach <name>}"
  docker exec -it "$name" tmux new-session -A -s rip-cage
}

cmd_down() {
  local name="${1:?Error: name required. Usage: rc down <name>}"
  if ! docker stop "$name" >/dev/null 2>&1; then
    [[ "$OUTPUT_FORMAT" == "json" ]] && json_error "Container not found: $name" "CONTAINER_NOT_FOUND"
    echo "Error: container $name not found or already stopped" >&2; exit 1
  fi
  if [[ "$OUTPUT_FORMAT" == "json" ]]; then
    json_out "{\"name\":\"$name\",\"action\":\"stopped\",\"status\":\"exited\"}"
  else
    echo "Container $name stopped."
  fi
}

cmd_destroy() {
  local name="${1:?Error: name required. Usage: rc destroy <name>}"
  if ! docker rm -f "$name" >/dev/null 2>&1; then
    [[ "$OUTPUT_FORMAT" == "json" ]] && json_error "Container not found: $name" "CONTAINER_NOT_FOUND"
    echo "Error: container $name not found" >&2; exit 1
  fi
  local volumes_removed=()
  for vol in "rc-state-${name}" "rc-history-${name}"; do
    if docker volume rm "$vol" 2>/dev/null; then
      volumes_removed+=("$vol")
    else
      log "Warning: volume $vol not found"
    fi
  done
  if [[ "$OUTPUT_FORMAT" == "json" ]]; then
    local vol_json
    vol_json=$(printf '%s\n' "${volumes_removed[@]}" | jq -R . | jq -sc .)
    json_out "{\"name\":\"$name\",\"action\":\"destroyed\",\"volumes_removed\":$vol_json}"
  else
    echo "Container $name and volumes destroyed."
  fi
}

cmd_test() {
  local name="${1:?Error: name required. Usage: rc test <name>}"
  if [[ "$OUTPUT_FORMAT" == "json" ]]; then
    local output
    output=$(docker exec "$name" /usr/local/lib/rip-cage/test-safety-stack.sh 2>&1) || true
    local -A check_names=(
      [1]="dcg_deny" [2]="block_compound_deny" [3]="settings_auto_mode"
      [4]="settings_dcg_hook" [5]="settings_block_compound_hook" [6]="claude_version"
    )
    local checks="{}" overall="pass"
    for i in 1 2 3 4 5 6; do
      if echo "$output" | grep -q "Test $i:.*PASS"; then
        checks=$(echo "$checks" | jq --arg k "${check_names[$i]}" '. + {($k): "pass"}')
      else
        checks=$(echo "$checks" | jq --arg k "${check_names[$i]}" '. + {($k): "fail"}')
        overall="fail"
      fi
    done
    json_out "{\"name\":\"$name\",\"checks\":$checks,\"overall\":\"$overall\"}"
  else
    docker exec "$name" /usr/local/lib/rip-cage/test-safety-stack.sh
  fi
}

# Parse global flags
while [[ $# -gt 0 ]]; do
  case "$1" in
    --output)
      if [[ "${2:-}" == "json" ]]; then
        OUTPUT_FORMAT="json"; shift 2
      else
        echo "Error: --output requires 'json'" >&2; exit 1
      fi
      ;;
    --dry-run) DRY_RUN=true; shift ;;
    *) break ;;  # first non-flag arg is the subcommand
  esac
done

# Main dispatch
case "${1:-}" in
  build)   shift; cmd_build "$@" ;;
  init)    shift; cmd_init "$@" ;;
  up)      shift; cmd_up "$@" ;;
  ls)      shift; cmd_ls "$@" ;;
  attach)  shift; cmd_attach "$@" ;;
  down)    shift; cmd_down "$@" ;;
  destroy) shift; cmd_destroy "$@" ;;
  test)    shift; cmd_test "$@" ;;
  *)       usage ;;
esac
